# Flask
SECRET_KEY=change-this-to-a-random-secret

# Figma — Personal access token from a Full/Dev seat account
# https://www.figma.com/developers/api#access-tokens
FIGMA_API_KEY=figd_your_token_here

# Otari AI — https://otari.ai
OTARI_API_KEY=tk_your_token_here
OTARI_MODEL=mzai:moonshotai/Kimi-K2.6
OTARI_BASE_URL=https://api.otari.ai/v1

# Gradium — speech-to-text for meeting recordings
# https://gradium.ai
GRADIUM_API_KEY=your_gradium_key_here

# GitHub — PAT with repo read access
GITHUB_TOKEN=ghp_your_token_here
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here
